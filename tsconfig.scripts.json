{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2019",
    "lib": ["ES2019"],
    "downlevelIteration": true,
    "noEmit": false,
    "outDir": "dist-scripts",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/scripts/**/*.ts", "src/lib/**/*.ts", "src/types/**/*.ts"]
}
